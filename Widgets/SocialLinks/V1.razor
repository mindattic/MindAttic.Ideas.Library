@namespace MindAttic.Ideas.Widget.SocialLinks
@inherits WidgetBase
@attribute [Idea(DisplayName = "Social Links")]

@* MindAttic.Ideas.Widget.SocialLinks.V1 — a row of social/profile icon links. Each known network is
   a string [Parameter]; set the ones you want and the row renders only those, with inline SVG icons
   (vector data in the markup — no icon files, no font, no requests). Per-site values can come from
   site settings ("social.github", …) so one theme token serves every site.
   {{ MindAttic.Ideas.Widget.SocialLinks github="https://github.com/mindattic" email="hi@mindattic.com" }} *@
<link rel="stylesheet" href="/_ideas/Widget/sociallinks/1/sociallinks.css" />
@if (_links.Count > 0)
{
    <ul class="ma-social" aria-label="Profiles">
        @foreach (var (name, href, path) in _links)
        {
            <li class="ma-social-item">
                <a class="ma-social-link" href="@href" target="_blank" rel="noopener noreferrer" aria-label="@name" title="@name">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="@path" /></svg>
                </a>
            </li>
        }
    </ul>
}

@code {
    /// <summary>GitHub profile URL. Falls back to the "social.github" site setting.</summary>
    [Parameter] public string? GitHub { get; set; }

    /// <summary>X / Twitter profile URL. Falls back to "social.x".</summary>
    [Parameter] public string? X { get; set; }

    /// <summary>LinkedIn profile URL. Falls back to "social.linkedin".</summary>
    [Parameter] public string? LinkedIn { get; set; }

    /// <summary>YouTube channel URL. Falls back to "social.youtube".</summary>
    [Parameter] public string? YouTube { get; set; }

    /// <summary>Contact email (address or mailto:). Falls back to "social.email".</summary>
    [Parameter] public string? Email { get; set; }

    /// <summary>Personal website URL. Falls back to "social.website".</summary>
    [Parameter] public string? Website { get; set; }

    /// <summary>RSS feed URL. Falls back to "social.rss".</summary>
    [Parameter] public string? Rss { get; set; }

    private IReadOnlyList<(string Name, string Href, string Path)> _links =
        Array.Empty<(string, string, string)>();

    protected override void OnParametersSet()
    {
        var links = new List<(string, string, string)>();
        Add(links, "GitHub", GitHub, "social.github", Icons.GitHub);
        Add(links, "X", X, "social.x", Icons.X);
        Add(links, "LinkedIn", LinkedIn, "social.linkedin", Icons.LinkedIn);
        Add(links, "YouTube", YouTube, "social.youtube", Icons.YouTube);
        Add(links, "Email", Mailto(FirstNonEmpty(Email, Setting("social.email"))), null, Icons.Email);
        Add(links, "Website", Website, "social.website", Icons.Website);
        Add(links, "RSS", Rss, "social.rss", Icons.Rss);
        _links = links;
    }

    private void Add(List<(string, string, string)> links, string name, string? value, string? settingKey, string icon)
    {
        var href = FirstNonEmpty(value, settingKey is null ? null : Setting(settingKey));
        if (!string.IsNullOrWhiteSpace(href)) links.Add((name, href, icon));
    }

    private string? Setting(string key) => Context?.Site?.GetSetting(key);

    private static string? Mailto(string? email) =>
        string.IsNullOrWhiteSpace(email) ? null
        : email.StartsWith("mailto:", StringComparison.OrdinalIgnoreCase) ? email : "mailto:" + email;

    private static string? FirstNonEmpty(params string?[] values) =>
        values.FirstOrDefault(v => !string.IsNullOrWhiteSpace(v));

