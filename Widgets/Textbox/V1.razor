@namespace MindAttic.Ideas.Widget.Textbox
@inherits WidgetBase

@* MindAttic.Ideas.Widget.Textbox.V1 — an Angular-Material-style OUTLINED text field: the label sits in
   the box at rest and floats up to OVERLAP the top border on focus/fill. Demonstrates a Widget that is
   configured like a React/Angular component — typed [Parameter] props (Label / Type / Value) PLUS
   pass-through attributes (WidgetBase.Attributes spread onto the <input>, e.g. required, maxlength,
   data-*). Styled by its own bundled css, served from this .idea's wwwroot at /_ideas/Widget/textbox/1/. *@
<link rel="stylesheet" href="/_ideas/Widget/textbox/1/textbox.css" />
<div class="ma-field">
    <input class="ma-field-input" type="@Type" value="@Value"
           placeholder=" " @attributes="Attributes" id="@InputId" />
    <label for="@InputId" class="ma-field-label">@Label</label>
</div>

@code {
    /// <summary>The floating label text.</summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>Input type (text, email, password, …). Defaults to text.</summary>
    [Parameter] public string Type { get; set; } = "text";

    /// <summary>Initial value.</summary>
    [Parameter] public string? Value { get; set; }

    // Stable per-instance id so the <label for> binds to this input (unique across multiple placements).
    // A caller-supplied id (via the attribute bag) wins, and the label must follow it — so the explicit
    // id sits after the @attributes spread and both elements read the same resolved value.
    private readonly string _id = "ma-tb-" + Guid.NewGuid().ToString("N").Substring(0, 8);

    private string InputId =>
        Attributes is not null && Attributes.TryGetValue("id", out var custom) && custom is not null
            ? custom.ToString()!
            : _id;
}
