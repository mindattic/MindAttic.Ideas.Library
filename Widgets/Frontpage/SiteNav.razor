@namespace MindAttic.Ideas.Widget.Frontpage

@* Whole-site navigation as one nested side-tab system.

   Outer level  : an accordion of sections (Portfolio, Software, Ecosystem,
                  Hardware, Writing, Visual Arts). Exactly one section is open
                  at a time — opening one collapses the previous.
   Inner level  : the open section's children render as a vertical tab rail on
                  the left; selecting one shows its preview (1:1.41 DVD-case
                  image) plus description and links on the right.

   The "ecosystem" (diagram) section has no children — it renders its IntroHtml
   (the SVG) directly in the panel. Cover images resolve under AssetBase. *@

<div class="siteNav">
    @foreach (var s in Sections)
    {
        var isOpen = s.Key == _openKey;
        <section class="siteNav-section @(isOpen ? "is-open" : null)">
            <h2 class="siteNav-headWrap">
                <button type="button" class="siteNav-head" @onclick="() => ToggleSection(s)"
                        aria-expanded="@(isOpen ? "true" : "false")">
                    <span class="siteNav-head-title">@s.Title</span>
                    <span class="siteNav-head-meta">
                        @if (s.Kind != "diagram") { <span class="siteNav-head-count">@s.Pages.Count</span> }
                        <span class="siteNav-chevron" aria-hidden="true"></span>
                    </span>
                </button>
            </h2>

            @if (isOpen)
            {
                <div class="siteNav-body">
                    @if (s.Kind == "diagram")
                    {
                        @if (!string.IsNullOrEmpty(s.IntroHtml))
                        {
                            <div class="siteNav-diagram">@((MarkupString)s.IntroHtml)</div>
                        }
                    }
                    else if (s.Pages.Count == 0)
                    {
                        <p class="muted">Nothing here yet.</p>
                    }
                    else
                    {
                        var sel = SelectedPage(s);
                        <div class="siteNav-tabs">
                            <nav class="siteNav-list" aria-label="@s.Title projects">
                                @foreach (var p in s.Pages)
                                {
                                    <NavTabItem Page="p"
                                                Selected="sel is not null && p.Slug == sel.Slug"
                                                OnSelect="slug => SelectChild(s.Key, slug)" />
                                }
                            </nav>

                            <div class="siteNav-panel">
                                @if (sel is not null)
                                {
                                    <div class="siteNav-preview @(sel.Cover is null ? "is-placeholder" : null)">
                                        @if (sel.Cover is not null)
                                        {
                                            <img src="@($"{AssetBase}/covers/{sel.Cover}")" alt="@sel.Title" />
                                        }
                                    </div>

                                    <div class="siteNav-detail">
                                        <h3 class="siteNav-detail-title">@sel.Title</h3>
                                        @if (!string.IsNullOrWhiteSpace(sel.Tagline))
                                        {
                                            <p class="siteNav-detail-tagline">@sel.Tagline</p>
                                        }

                                        <div class="siteNav-links">
                                            @if (!string.IsNullOrWhiteSpace(sel.OpenUrl))
                                            {
                                                <a class="tabButton-btn" href="@sel.OpenUrl" target="_blank" rel="noopener noreferrer">Open</a>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(sel.GitHubUrl))
                                            {
                                                <a class="tabButton-btn" href="@sel.GitHubUrl" target="_blank" rel="noopener noreferrer">GitHub</a>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<HubSection> Sections { get; set; } = [];
    [Parameter] public string AssetBase { get; set; } = "";

    private string? _openKey;
    private readonly Dictionary<string, string> _selected = new();

    protected override void OnParametersSet()
    {
        // Default: first section open, its first child selected.
        if (_openKey is null && Sections.Count > 0)
        {
            _openKey = Sections[0].Key;
            EnsureSelection(Sections[0]);
        }
    }

    private void ToggleSection(HubSection s)
    {
        _openKey = (_openKey == s.Key) ? null : s.Key;
        if (_openKey == s.Key) EnsureSelection(s);
    }

    private void SelectChild(string sectionKey, string slug) => _selected[sectionKey] = slug;

    private void EnsureSelection(HubSection s)
    {
        if (s.Kind == "diagram" || s.Pages.Count == 0) return;
        if (!_selected.ContainsKey(s.Key))
            _selected[s.Key] = s.Pages[0].Slug;
    }

    private HubPage? SelectedPage(HubSection s)
    {
        if (s.Pages.Count == 0) return null;
        if (_selected.TryGetValue(s.Key, out var slug))
        {
            var match = s.Pages.FirstOrDefault(p => p.Slug == slug);
            if (match is not null) return match;
        }
        return s.Pages[0];
    }
}
