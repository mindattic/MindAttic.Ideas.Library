@namespace MindAttic.Ideas.Plugin.LegionPersonas

<button class="persona-card" @onclick="OnClick" type="button">
    <div class="persona-art">
        @* SacredGeometry plugin's auto-init driver animates shape N onto this canvas. *@
        <canvas class="persona-art-canvas" data-sacred-shape="@Persona.Shape" data-sacred-bg="#0a1014"></canvas>
    </div>
    <div class="persona-card-body">
        <div class="persona-card-name">@Persona.Name</div>
        <div class="persona-card-sub">@Persona.Worldview @Persona.Archetype</div>
        <div class="persona-card-tags">
            @if (Persona.MbtiType is not null) { <span class="tag tag-accent">@Persona.MbtiType</span> }
            @if (Persona.EnneagramType is not null) { <span class="tag">@Persona.EnneagramType</span> }
            @if (Persona.DiscPrimary is not null) { <span class="tag">DISC-@Persona.DiscPrimary</span> }
        </div>
    </div>
</button>

@code {
    [Parameter, EditorRequired] public Persona Persona { get; set; } = default!;
    [Parameter] public EventCallback OnClick { get; set; }
}
