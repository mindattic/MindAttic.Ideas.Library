@namespace MindAttic.Ideas.Theme.Summer
@inherits ThemeBase
@attribute [Idea(DisplayName = "Summer")]

@* MindAttic.Ideas.Theme.Summer.V1 — a self-contained Summer theme: chrome (theme.css) + ONE @Body hole.
   All look/feel ships in this theme's own assets/theme.css (served at /_ideas/Theme/summer/1/), scoped
   under .theme-summer so it never leaks into widgets or other themes. *@
<div class="page theme-summer">
    @Body
</div>

@code {
    private const string Mount = "/_ideas/Theme/summer/1";
    public override IReadOnlyList<string> ThemeCssUrls { get; } = new[] { Mount + "/theme.css" };
}
