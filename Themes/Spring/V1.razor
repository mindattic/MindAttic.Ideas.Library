@namespace MindAttic.Ideas.Theme.Spring
@inherits ThemeBase
@attribute [Idea(DisplayName = "Spring")]

@* MindAttic.Ideas.Theme.Spring.V1 — a self-contained Spring theme: chrome (theme.css) + ONE @Body hole.
   All look/feel ships in this theme's own assets/theme.css (served at /_ideas/Theme/spring/1/), scoped
   under .theme-spring so it never leaks into widgets or other themes. *@
<div class="page theme-spring">
    @Body
</div>

@code {
    private const string Mount = "/_ideas/Theme/spring/1";
    public override IReadOnlyList<string> ThemeCssUrls { get; } = new[] { Mount + "/theme.css" };
}
