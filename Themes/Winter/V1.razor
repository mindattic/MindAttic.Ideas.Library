@namespace MindAttic.Ideas.Theme.Winter
@inherits ThemeBase
@attribute [Idea(DisplayName = "Winter")]

@* MindAttic.Ideas.Theme.Winter.V1 — a self-contained Winter theme: chrome (theme.css) + ONE @Body hole.
   All look/feel ships in this theme's own assets/theme.css (served at /_ideas/Theme/winter/1/), scoped
   under .theme-winter so it never leaks into widgets or other themes. *@
<div class="page theme-winter">
    @Body
</div>

@code {
    private const string Mount = "/_ideas/Theme/winter/1";
    public override IReadOnlyList<string> ThemeCssUrls { get; } = new[] { Mount + "/theme.css" };
}
