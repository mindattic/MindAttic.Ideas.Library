<Project Sdk="Microsoft.NET.Sdk.Razor">

  <!-- Autumn theme. Common props + the Abstractions reference come from ../../Directory.Build.props.
       Identity by convention: namespace tail (autumn) + V{n} class -> Theme/autumn/1. Self-contained chrome
       lives in assets/theme.css (a PLAIN folder, NOT wwwroot/, so StaticWebAssetsEnabled=false keeps the
       Razor SDK from claiming it). At pack time assets/ IS the package wwwroot, served at
       /_ideas/Theme/autumn/1/. -->
  <PropertyGroup>
    <StaticWebAssetsEnabled>false</StaticWebAssetsEnabled>
  </PropertyGroup>

</Project>
