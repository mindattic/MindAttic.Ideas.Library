@namespace MindAttic.Ideas.Theme.Light
@inherits ThemeBase
@attribute [Idea(DisplayName = "Light")]

@* MindAttic.Ideas.Theme.Light.V1 — a self-contained Light theme: chrome (theme.css) + ONE @Body hole.
   All look/feel ships in this theme's own assets/theme.css (served at /_ideas/Theme/light/1/), scoped
   under .theme-light so it never leaks into widgets or other themes. *@
<div class="page theme-light">
    @Body
</div>

@code {
    private const string Mount = "/_ideas/Theme/light/1";
    public override IReadOnlyList<string> ThemeCssUrls { get; } = new[] { Mount + "/theme.css" };
}
