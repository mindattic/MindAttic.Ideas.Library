@namespace MindAttic.Ideas.Page.Frontpage
@inherits MindAttic.Ideas.Abstractions.PageBase
@attribute [MindAttic.Ideas.Abstractions.Idea(DisplayName = "MindAttic Frontpage")]

@* MindAttic.Ideas.Page.Frontpage.V1 — the MindAttic corporate front page, as a single
   compiled Page Idea. Renders the whole-site accordion (Portfolio / Software / Ecosystem / Hardware
   / Writing / Visual Arts) from self-contained bundled data — no database, no API. Its stylesheet is
   emitted inline so the Page renders correctly under any host theme. Packs into
   MindAttic.Ideas.Page.Frontpage.V1.idea. *@

<HeadContent>
    <style>@((MarkupString)HubContent.Css)</style>
</HeadContent>

<SiteNav Sections="HubContent.Sections" AssetBase="@AssetBase" />

@code {
    // Compiled RCL static web assets are served at _content/{AssemblyName}/. When this Page is loaded
    // as a runtime .idea (Phase 5), swap this for the host's package asset mount (/_ideas/{key}/{ver}).
    private const string AssetBase = "_content/MindAttic.Ideas.Page.Frontpage";
}
