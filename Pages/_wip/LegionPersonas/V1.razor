@namespace MindAttic.Ideas.Page.LegionPersonas
@inherits PageBase
@attribute [Idea(DisplayName = "Legion Personas", RenderMode = CmsRenderMode.InteractiveServer)]
@attribute [Uses(ContentKind.Plugin, "sacredgeometry", 1)]

@* ============================================================================================
   MindAttic.Ideas.Page.LegionPersonas.V1 — the MindAttic.Legion 1024-persona gallery as a single
   compiled Page shipped as a .idea. Identity by convention: namespace tail "LegionPersonas" => key
   "legionpersonas", class "V1" => version 1. The persona library is the embedded personas.json
   (PersonaData); each card's live avatar is a SacredGeometry shape, animated by the SacredGeometry
   Plugin (composed BY STRING ID — never compiled against). The page wears the Cyberspace theme,
   chosen in data/page.json. All CSS is scoped under .legion-personas so it never leaks into the host.
   ============================================================================================ *@

<div class="legion-personas">
@* Switch ON the SacredGeometry capability: loads the renderer + the canvas[data-sacred-shape] animator. *@
<CmsInclude Ref="MindAttic.Ideas.Plugin.SacredGeometry.V1" />

<div class="gallery">
    <aside class="filters">
        <h1 class="brand">Legion Personas</h1>
        <p class="muted small">@PersonaData.All.Count personas · @PersonaData.ScoredCount scored</p>

        <input class="f-control" type="search" placeholder="Search name, prompt, quirk…"
               @bind="filter.Text" @bind:event="oninput" @bind:after="OnFilterChanged" />

        <label class="f-label">Archetype</label>
        <select class="f-control" @bind="filter.Archetype" @bind:after="OnFilterChanged">
            <option value="">Any archetype</option>
            @foreach (var v in PersonaData.Archetypes) { <option value="@v">@v</option> }
        </select>

        <label class="f-label">Worldview</label>
        <select class="f-control" @bind="filter.Worldview" @bind:after="OnFilterChanged">
            <option value="">Any worldview</option>
            @foreach (var v in PersonaData.Worldviews) { <option value="@v">@v</option> }
        </select>

        <label class="f-label">Background</label>
        <select class="f-control" @bind="filter.Background" @bind:after="OnFilterChanged">
            <option value="">Any background</option>
            @foreach (var v in PersonaData.Backgrounds) { <option value="@v">@v</option> }
        </select>

        <label class="f-label">Pronouns</label>
        <select class="f-control" @bind="filter.Pronouns" @bind:after="OnFilterChanged">
            <option value="">Any pronouns</option>
            @foreach (var v in PersonaData.Pronouns) { <option value="@v">@v</option> }
        </select>

        <label class="f-label">MBTI type</label>
        <select class="f-control" @bind="filter.MbtiType" @bind:after="OnFilterChanged">
            <option value="">Any type</option>
            @foreach (var v in PersonaData.MbtiTypes) { <option value="@v">@v</option> }
        </select>

        <label class="f-label">DISC primary</label>
        <select class="f-control" @bind="filter.DiscPrimary" @bind:after="OnFilterChanged">
            <option value="">Any style</option>
            @foreach (var v in PersonaData.DiscStyles) { <option value="@v">DISC-@v</option> }
        </select>

        <label class="f-label">Enneagram</label>
        <select class="f-control" @bind="filter.EnneagramType" @bind:after="OnFilterChanged">
            <option value="">Any</option>
            @foreach (var t in PersonaData.EnneagramTypes) { <option value="@t">Type @t</option> }
        </select>

        <label class="f-label">Age @filter.MinAge–@filter.MaxAge</label>
        <div class="f-row">
            <input class="f-control" type="number" min="0" max="120" @bind="filter.MinAge" @bind:after="OnFilterChanged" />
            <input class="f-control" type="number" min="0" max="120" @bind="filter.MaxAge" @bind:after="OnFilterChanged" />
        </div>

        <button class="f-clear" type="button" @onclick="Clear">Clear filters</button>
    </aside>

    <section class="results">
        <div class="results-head">
            <span class="muted">@filtered.Count match@(filtered.Count == 1 ? "" : "es")</span>
            <span class="results-tools">
                <label class="page-size">
                    Per page
                    <select @bind="pageSize" @bind:after="OnPageSizeChanged">
                        @foreach (var size in PageSizes) { <option value="@size">@size</option> }
                    </select>
                </label>
                @if (PageCount > 1)
                {
                    <span class="pager">
                        <button type="button" @onclick="Prev" disabled="@(page == 0)">‹</button>
                        page @(page + 1) / @PageCount
                        <button type="button" @onclick="Next" disabled="@(page >= PageCount - 1)">›</button>
                    </span>
                }
            </span>
        </div>

        <div class="card-grid">
            @foreach (var p in PageItems)
            {
                <PersonaCard Persona="p" OnClick="() => Select(p)" />
            }
        </div>
    </section>

    @if (selected is not null)
    {
        <div class="detail-overlay" @onclick="Close">
            <div class="detail-panel" @onclick:stopPropagation="true">
                <PersonaDetail Persona="selected" OnClose="Close" />
            </div>
        </div>
    }
</div>
</div>

@code {
    private static readonly int[] PageSizes = { 250, 500, 1000 };

    private readonly PersonaFilter filter = new();
    private List<Persona> filtered = new();
    private int pageSize = PageSizes[0];
    private int page;
    private Persona? selected;

    protected override void OnInitialized() => Recompute();

    private void Recompute()
    {
        filtered = PersonaFiltering.Apply(PersonaData.All, filter).ToList();
        if (page >= PageCount) page = 0;
    }

    private void OnFilterChanged() { page = 0; Recompute(); }

    private void OnPageSizeChanged() { page = 0; Recompute(); }

    private void Clear()
    {
        filter.Text = filter.Archetype = filter.Worldview = filter.Background =
            filter.Pronouns = filter.MbtiType = filter.DiscPrimary = "";
        filter.EnneagramType = null;
        filter.MinAge = 0;
        filter.MaxAge = 120;
        OnFilterChanged();
    }

    private int PageCount => Math.Max(1, (int)Math.Ceiling(filtered.Count / (double)pageSize));
    private IEnumerable<Persona> PageItems => filtered.Skip(page * pageSize).Take(pageSize);

    private void Prev() { if (page > 0) page--; }
    private void Next() { if (page < PageCount - 1) page++; }

    private void Select(Persona p) => selected = p;
    private void Close() => selected = null;
}

<style>
    /* All selectors scoped under .legion-personas so the page never leaks styles into the host/theme. */
    .legion-personas {
        --bg: #0b0e14;
        --panel: #121723;
        --panel-2: #1a2130;
        --line: #232c3d;
        --text: #dce1e6;
        --muted: #8b97a8;
        --accent: #3c82ff;
        color: var(--text);
    }
    .legion-personas * { box-sizing: border-box; }
    .legion-personas .muted { color: var(--muted); }
    .legion-personas .small { font-size: 0.82rem; }

    /* ── layout ───────────────────────────────────────────── */
    .legion-personas .gallery { display: grid; grid-template-columns: 280px 1fr; min-height: 100vh; }

    .legion-personas .filters {
        background: var(--panel);
        border-right: 1px solid var(--line);
        padding: 1.25rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        position: sticky;
        top: 0;
        align-self: start;
        height: 100vh;
        overflow-y: auto;
    }
    .legion-personas .brand { font-size: 1.4rem; font-weight: 800; margin: 0 0 0.1rem; letter-spacing: -0.01em; color: var(--text); }
    .legion-personas .f-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-top: 0.4rem; }
    .legion-personas .f-control {
        width: 100%;
        background: var(--panel-2);
        color: var(--text);
        border: 1px solid var(--line);
        border-radius: 7px;
        padding: 0.45rem 0.55rem;
        font: inherit;
    }
    .legion-personas .f-row { display: flex; gap: 0.4rem; }
    .legion-personas .f-clear {
        margin-top: 0.8rem;
        background: transparent; color: var(--muted);
        border: 1px solid var(--line); border-radius: 7px;
        padding: 0.45rem; cursor: pointer;
    }
    .legion-personas .f-clear:hover { color: var(--text); border-color: var(--accent); }

    /* ── results ──────────────────────────────────────────── */
    .legion-personas .results { padding: 1.25rem 1.5rem; }
    .legion-personas .results-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
    .legion-personas .pager button {
        background: var(--panel-2); color: var(--text); border: 1px solid var(--line);
        border-radius: 6px; padding: 0.2rem 0.6rem; cursor: pointer; margin: 0 0.2rem;
    }
    .legion-personas .pager button:disabled { opacity: 0.4; cursor: default; }

    .legion-personas .results-tools { display: flex; align-items: center; gap: 1rem; }
    .legion-personas .page-size {
        display: inline-flex; align-items: center; gap: 0.4rem;
        color: var(--muted); font-size: 0.85rem;
    }
    .legion-personas .page-size select {
        background: var(--panel-2); color: var(--text); border: 1px solid var(--line);
        border-radius: 6px; padding: 0.2rem 0.4rem; cursor: pointer;
    }

    .legion-personas .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1rem;
    }

    /* ── persona card ─────────────────────────────────────── */
    .legion-personas .persona-card {
        background: var(--panel); border: 1px solid var(--line); border-radius: 12px;
        overflow: hidden; cursor: pointer; text-align: left; padding: 0; color: inherit;
        transition: transform 0.08s ease, border-color 0.08s ease;
    }
    .legion-personas .persona-card:hover { transform: translateY(-2px); border-color: var(--accent); }
    .legion-personas .persona-art { width: 100%; aspect-ratio: 1 / 1.41; background: #0a1014; position: relative; }
    .legion-personas .persona-art-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
    .legion-personas .persona-card-body { padding: 0.6rem 0.7rem 0.8rem; }
    .legion-personas .persona-card-name { font-weight: 600; }
    .legion-personas .persona-card-sub { color: var(--muted); font-size: 0.8rem; margin: 0.1rem 0 0.4rem; line-height: 1.2; }
    .legion-personas .persona-card-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
    .legion-personas .tag { background: var(--panel-2); border: 1px solid var(--line); border-radius: 999px; padding: 0.05rem 0.5rem; font-size: 0.72rem; color: var(--muted); }
    .legion-personas .tag-accent { color: var(--accent); border-color: var(--accent); }

    /* ── detail overlay ───────────────────────────────────── */
    .legion-personas .detail-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,0.6);
        display: flex; justify-content: center; align-items: flex-start; padding: 4vh 1rem; z-index: 50;
    }
    .legion-personas .detail-panel {
        background: var(--panel); border: 1px solid var(--line); border-radius: 14px;
        max-width: 640px; width: 100%; max-height: 92vh; overflow-y: auto; padding: 1.4rem;
    }
    .legion-personas .persona-detail-head { display: flex; gap: 1rem; align-items: center; }
    .legion-personas .persona-art-lg { width: 88px; aspect-ratio: 1 / 1.41; border-radius: 12px; flex: 0 0 auto; }
    .legion-personas .persona-detail-title h2 { margin: 0; }
    .legion-personas .close-btn { margin-left: auto; background: transparent; border: none; color: var(--muted); font-size: 1.2rem; cursor: pointer; }
    .legion-personas .close-btn:hover { color: var(--text); }
    .legion-personas .persona-bio { white-space: pre-wrap; line-height: 1.5; color: var(--text); margin: 1rem 0; }
    .legion-personas .section { margin: 1.2rem 0 0.4rem; font-size: 1rem; }
    .legion-personas .trait-grid { display: grid; grid-template-columns: 120px 1fr; gap: 0.25rem 0.8rem; margin: 0; }
    .legion-personas .trait { display: contents; }
    .legion-personas .trait dt { color: var(--muted); }
    .legion-personas .trait dd { margin: 0; }
    .legion-personas .scored-line { margin-top: 1rem; }

    @@media (max-width: 720px) {
        .legion-personas .gallery { grid-template-columns: 1fr; }
        .legion-personas .filters { position: static; height: auto; }
    }
</style>
